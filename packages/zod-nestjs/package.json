{
  "name": "@clearlovesixteen/zod-nestjs",
  "version": "0.1.0",
  "description": "NestJS pipes and decorators for normalized Gancao Zod validation",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root ../.. packages/zod-nestjs/test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clearlovesixteen/zod-core": "0.1.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0 <12",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clearlovesixteen/gancao-zod.git",
    "directory": "packages/zod-nestjs"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
