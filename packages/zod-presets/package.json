{
  "name": "@clearlovesixteen/zod-presets",
  "version": "0.2.0",
  "description": "Reusable Zod schemas for Gancao applications",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root ../.. packages/zod-presets/test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clearlovesixteen/gancao-zod.git",
    "directory": "packages/zod-presets"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
