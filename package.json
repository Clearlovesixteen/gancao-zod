{
  "name": "gancao-zod",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod validation tooling for Gancao TypeScript applications",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "clean": "npm run clean --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "react": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2"
}
