{
  "name": "gancao-zod",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod validation tooling for Gancao TypeScript applications",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"packages/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{ts,mjs}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{ts,mjs}\"",
    "check:packages": "node scripts/check-packages.mjs",
    "audit:production": "npm audit --omit=dev",
    "clean": "npm run clean --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@nestjs/common": "^11.0.0",
    "@types/express": "^5.0.0",
    "eslint": "^9.0.0",
    "express": "^5.0.0",
    "prettier": "^3.9.0",
    "react": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "packageManager": "npm@10.8.2"
}
